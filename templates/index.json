    "faq": {
      "type": "collapsible-content",
      "settings": {
        "caption": "Need a hand?",
        "heading": "Frequently asked questions",
        "heading_size": "h1",
        "heading_alignment": "center",
        "layout": "none",
        "container_color_scheme": "scheme-2",
        "color_scheme": "scheme-2",
        "open_first_collapsible_row": false,
        "image_ratio": "adapt",
        "desktop_layout": "image_second",
        "footer_text": "<p>Still have a question? <a href=\"/pages/contact\">Contact us</a> · info@celinebeaumont.com</p>",
        "padding_top": 64,
        "padding_bottom": 72
      },
      "blocks": {
        "q1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you offer free shipping?",
            "icon": "none",
            "row_content": "<p>Yes — we offer complimentary shipping on all Canadian orders, with no minimum spend. Orders ship within 1–2 business days.</p>"
          }
        },
        "q2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is your return policy?",
            "icon": "none",
            "row_content": "<p>We accept easy returns within 30 days on most items. A few final-sale pieces are clearly marked before purchase.</p>"
          }
        },
        "q3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How can I track my order?",
            "icon": "none",
            "row_content": "<p>As soon as your order ships, you'll receive an email with a tracking link so you can follow it every step of the way.</p>"
          }
        },
        "q4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What payment methods do you accept?",
            "icon": "none",
            "row_content": "<p>We accept all major credit cards, Apple Pay, Google Pay, PayPal, Shop Pay and more — all processed securely at checkout.</p>"
          }
        },
        "q5": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I find my size?",
            "icon": "none",
            "row_content": "<p>Every product page includes a size guide with detailed measurements. If you're between sizes or unsure, reach out to info@celinebeaumont.com and we're happy to help.</p>"
          }
        }
      },
      "block_order": [
        "q1",
        "q2",
        "q3",
        "q4",
        "q5"
      ]
    }
