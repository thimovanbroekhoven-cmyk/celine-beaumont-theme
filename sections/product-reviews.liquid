{% comment %}
  Celine Beaumont: static placeholder product reviews, styled like the homepage testimonials.

  IMPORTANT: this is static block content edited in the theme editor, not real per-product
  review data. Before launch, replace this section with a real reviews app (e.g. Judge.me or
  Loox) so review content is genuinely tied to each product and collected from real customers.
  See DEPLOYMENT.md.
{% endcomment %}

{{ 'component-rating.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .cb-stars {
    display: inline-flex;
    gap: 0.15em;
    color: #c9a86a;
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 1.6rem;
  }
  .cb-star--empty {
    opacity: 0.28;
  }
{%- endstyle -%}

<div class="testimonials product-reviews color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="testimonials__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__heading inline-richtext">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <ul class="testimonials__grid list-unstyled" role="list">
      {%- for block in section.blocks -%}
        <li class="testimonials__item" {{ block.shopify_attributes }}>
          {%- assign cb_r = block.settings.rating | default: 5 -%}
          <div
            class="cb-stars"
            role="img"
            aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: block.settings.rating, rating_max: 5 }}"
          >
            {%- for i in (1..5) -%}<span aria-hidden="true" class="cb-star{% if i > cb_r %} cb-star--empty{% endif %}">★</span>{%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonials__quote">{{ block.settings.quote }}</blockquote>
          {%- endif -%}
          {%- if block.settings.name != blank -%}
            <p class="testimonials__name">{{ block.settings.name | escape }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "t:celine.schema.product_reviews.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:celine.schema.product_reviews.paragraph"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:celine.schema.testimonials.heading.label",
      "default": "t:celine.schema.product_reviews.heading_default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "t:celine.schema.testimonials.block.name",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:celine.schema.testimonials.block.rating.label",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "t:celine.schema.testimonials.block.quote.label",
          "default": "t:celine.schema.testimonials.block.quote.default"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:celine.schema.testimonials.block.name_label",
          "default": "t:celine.schema.testimonials.block.name_default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:celine.schema.product_reviews.name",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
