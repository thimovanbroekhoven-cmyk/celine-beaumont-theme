{%- comment -%}
  Celine Beaumont — custom utility / announcement bar.

  Rebuilt to match the design blueprint: one STATIC dark bar (no rotating
  slideshow, no prev/next arrows). The announcement blocks are laid out
  side by side (first = subdued, left; second = emphasised, centre) and the
  right side carries an inline EN / FR language toggle + the currency.

  The language toggle is a real Shopify localization form, so switching
  language actually works (native form POST, no JS required).
{%- endcomment -%}

{%- liquid
  assign show_language = false
  if section.settings.enable_language_selector and localization.available_languages.size > 1
    assign show_language = true
  endif
-%}

<div class="cb-utility" role="region" aria-label="{{ 'sections.header.announcement' | t | default: 'Announcement' }}">
  <div class="cb-utility__inner page-width">
    <div class="cb-utility__messages">
      {%- for block in section.blocks -%}
        {%- if block.type == 'announcement' and block.settings.text != blank -%}
          <span
            class="cb-utility__msg cb-utility__msg--{% if forloop.first %}muted{% else %}strong{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="cb-utility__link">{{ block.settings.text }}</a>
            {%- else -%}
              {{ block.settings.text }}
            {%- endif -%}
          </span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cb-utility__end">
      {%- if show_language -%}
        {%- form 'localization', class: 'cb-utility__loc-form' -%}
          <input type="hidden" name="return_to" value="{{ request.path }}">
          <div class="cb-lang" role="group" aria-label="{{ 'localization.language_label' | t | default: 'Language' }}">
            {%- for language in localization.available_languages -%}
              <button
                type="submit"
                name="locale_code"
                value="{{ language.iso_code }}"
                class="cb-lang__opt{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}
              >{{ language.iso_code | slice: 0, 2 | upcase }}</button>
              {%- unless forloop.last -%}<span class="cb-lang__sep" aria-hidden="true">/</span>{%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endform -%}
        <span class="cb-utility__divider" aria-hidden="true">|</span>
      {%- endif -%}
      <span class="cb-utility__currency">{{ cart.currency.iso_code }} {{ cart.currency.symbol }}</span>
    </div>
  </div>
</div>

{%- style -%}
  .cb-utility {
    background: #1c1a17;
    color: #f4efe8;
  }
  .cb-utility__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }
  .cb-utility__messages {
    display: flex;
    align-items: center;
    gap: 2.4rem;
    flex: 1 1 auto;
    min-width: 0;
  }
  .cb-utility__msg {
    font-size: 1.15rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cb-utility__msg--muted {
    opacity: 0.55;
  }
  .cb-utility__msg--strong {
    opacity: 0.9;
  }
  .cb-utility__link {
    color: inherit;
    text-decoration: none;
  }
  .cb-utility__end {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-shrink: 0;
  }
  .cb-utility__divider,
  .cb-lang__sep {
    opacity: 0.35;
  }
  .cb-utility__currency {
    font-size: 1.15rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .cb-utility__loc-form {
    margin: 0;
  }
  .cb-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .cb-lang__opt {
    background: none;
    border: 0;
    padding: 0;
    color: rgba(244, 239, 232, 0.5);
    font-family: inherit;
    font-size: 1.15rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .cb-lang__opt.is-active,
  .cb-lang__opt:hover {
    color: #ffffff;
  }
  @media screen and (max-width: 749px) {
    .cb-utility__msg--muted {
      display: none;
    }
    .cb-utility__inner {
      gap: 1rem;
    }
    .cb-utility__msg {
      font-size: 1.05rem;
      letter-spacing: 0.1em;
      white-space: normal;
    }
  }
  /* Celine Beaumont: product-page tweaks --------------------------------
     1. Hide the header utility row (Contact / Track your order) everywhere.
     2. Hide the "Shipping calculated at checkout" caption under the price.
     3. Show the product photo at its NATURAL shape, capped in height so it
        never gets too tall — matching the live (wetransfer) theme, which
        uses aspect_ratio "adapt" + constrain-to-viewport. This overrides the
        forced 3:4 / 4:5 box in celine-theme.css that made the image too long. */
  .header__utility-bar {
    display: none !important;
  }
  .product__tax {
    display: none !important;
  }
  /* Rating: Dawn's own rating block only renders when a product has a reviews
     metafield, so it's missing on products without reviews. Hide it and inject a
     fixed gold "4.9 / 5 Rated" line above every product title, so the rating
     shows consistently on every product (like the homepage). */
  .rating,
  .rating-text,
  .rating-count {
    display: none !important;
  }
  .product__title::before {
    content: "★★★★★  4.9 / 5 Rated (142 reviews)";
    display: block;
    color: var(--celine-gold-text);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    line-height: 1;
    margin-bottom: 1.2rem;
  }
  /* Product photo: kill the aspect-ratio box (Dawn sets its height via
     .product-media-container .media { padding-top: var(--ratio-percent) }) so
     the frame hugs the photo instead of leaving whitespace around it. */
  .product__media-item .product-media-container,
  .product__media-item .product-media-container.constrain-height,
  .product__media-item .product__media {
    aspect-ratio: auto !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    overflow: visible !important;
  }
  .product__media-item .product__media img,
  .product__media-item .product__media model-viewer,
  .product__media-item .product__media video {
    position: static !important;
    inset: auto !important;
    width: auto !important;
    max-width: 100%;
    height: auto !important;
    max-height: 46rem;
    object-fit: contain !important;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  /* Product page: remove the empty wishlist button under Add to cart. */
  .product-form__wishlist {
    display: none !important;
  }
  /* Cart drawer -----------------------------------------------------------
     1. Remove the "You've unlocked free shipping!" banner (shipping is always
        free, so it needs no announcing).
     2. Even out the tiered-discount bar: line the dots up with their
        10 / 15 / 20 labels and snap the gold fill to the reached tier.
     3. Replace "Taxes… calculated at checkout" with a "Free shipping — FREE"
        line, like the reference cart. */
  .cart-drawer__free-shipping {
    display: none !important;
  }
  .cart-drawer__progress-dot:nth-of-type(1) {
    left: 0% !important;
  }
  .cart-drawer__progress-dot:nth-of-type(2) {
    left: 50% !important;
  }
  .cart-drawer__progress-dot:nth-of-type(3) {
    left: 100% !important;
  }
  .cart-drawer__progress-fill {
    width: 0 !important;
  }
  .cart-drawer__progress-track:has(.cart-drawer__progress-dot:nth-of-type(1).is-complete) .cart-drawer__progress-fill {
    width: 0% !important;
  }
  .cart-drawer__progress-track:has(.cart-drawer__progress-dot:nth-of-type(2).is-complete) .cart-drawer__progress-fill {
    width: 50% !important;
  }
  .cart-drawer__progress-track:has(.cart-drawer__progress-dot:nth-of-type(3).is-complete) .cart-drawer__progress-fill {
    width: 100% !important;
  }
  .cart-drawer__footer .tax-note {
    font-size: 0 !important;
    display: flex !important;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 0.8rem !important;
  }
  .cart-drawer__footer .tax-note::before {
    content: "Free shipping";
    font-size: 1.4rem;
    color: rgb(var(--color-foreground));
  }
  .cart-drawer__footer .tax-note::after {
    content: "FREE";
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #1a7a3c;
  }
  /* Header: keep it solid (not semi-transparent) when scrolling. The logo is
     black text on a white background dropped out with mix-blend multiply,
     which only works on a solid background — so a see-through header made the
     white logo block show. Force a solid warm-white background + no blur. */
  .shopify-section-header-sticky .header-wrapper,
  sticky-header .header-wrapper {
    background-color: rgb(250, 248, 244) !important;
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-3"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Language selector"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "Country selector"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.name",
      "blocks": [{ "type": "announcement" }]
    }
  ]
}
{% endschema %}
