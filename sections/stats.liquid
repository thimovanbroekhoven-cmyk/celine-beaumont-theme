{% comment %}
  Celine Beaumont custom section (Dawn has no stats/numbers section): a simple row of
  big-number + label stat blocks on a cream background. Used on the About page.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="celine-stats color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <ul class="celine-stats__grid list-unstyled" role="list">
      {%- for block in section.blocks -%}
        <li class="celine-stats__item" {{ block.shopify_attributes }}>
          <p class="celine-stats__number">{{ block.settings.number | escape }}</p>
          <p class="celine-stats__label">{{ block.settings.label | escape }}</p>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "t:celine.schema.stats.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "t:celine.schema.stats.block.name",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:celine.schema.stats.block.number.label",
          "default": "t:celine.schema.stats.block.number.default"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:celine.schema.stats.block.label_label",
          "default": "t:celine.schema.stats.block.label_default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:celine.schema.stats.name",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
