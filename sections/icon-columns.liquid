{% comment %}
  Celine Beaumont custom section (Dawn has no equivalent): a row of icon + heading + text
  columns. Used for the homepage USP strip (dark scheme) and the product page "details band"
  (light/cream scheme) — the same section, made flexible via the standard color_scheme setting
  so either variant is just a theme-editor choice, not a code fork.

  Icons reuse Dawn's existing stroke-based icon set (assets/icon-*.svg, currentColor) via the
  shared 'icon-accordion' snippet, rather than inventing a new icon system.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="icon-columns color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.caption != blank or section.settings.heading != blank -%}
      <div class="icon-columns__header">
        {%- if section.settings.caption != blank -%}
          <p class="caption-with-letter-spacing">{{ section.settings.caption | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="icon-columns__heading inline-richtext">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="icon-columns__grid icon-columns__grid--{{ section.settings.columns_desktop }}-col">
      {%- for block in section.blocks -%}
        <div class="icon-columns__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != 'none' -%}
            <div class="icon-columns__icon">
              {% render 'icon-accordion', icon: block.settings.icon %}
            </div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h3 class="icon-columns__item-heading">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="icon-columns__item-text">{{ block.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

