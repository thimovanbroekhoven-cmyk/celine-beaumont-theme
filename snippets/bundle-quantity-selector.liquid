{% comment %}
  Renders the "Choose your quantity & save" bundle tier selector.

  This is the one genuinely custom (non-Dawn) piece of the product page. It lets a shopper pick a
  quantity tier (1 / 2 / 3 / 4+ units) and, for tiers above 1, choose a Color + Size combination
  per unit so a single "Buy 2" purchase can contain two different variants.

  IMPORTANT — what is and isn't real here:
  - The tier radios, per-unit variant selects, running totals and the final "add to cart" action
    are fully functional: selecting a tier shows/hides real <select> elements (never fake divs),
    and submitting genuinely POSTs one line item per unit to /cart/add.js with the shopper's
    chosen variant ID(s) — so it truly adds N line items to the Shopify cart.
  - The discounted per-item/total prices shown here are a client-side preview only. For the
    customer to actually be charged the discounted amount at checkout, a store admin must create
    a matching automatic discount (or Shopify Function) in Shopify Admin > Discounts with the
    same quantity thresholds (2/3/4) and percentages (10%/15%/20%). See DEPLOYMENT.md.

  Accepts:
  - product: {Object} product object
  - section_id: {String} id of the parent section, for unique element IDs
  - product_form_id: {String} id of the main product form (unused for submission — this block
    intentionally submits independently via /cart/add.js so it can add multiple line items)

  Usage:
  {% render 'bundle-quantity-selector', product: product, section_id: section.id %}
{% endcomment %}
{%- unless product == blank -%}
  {{ 'component-bundle-quantity-selector.css' | asset_url | stylesheet_tag }}

  {%- liquid
    assign celine_bundle_max_units = 4
    assign celine_compare_price = product.compare_at_price | default: product.price
    assign celine_base_price = product.price
  -%}

  <bundle-quantity-selector
    class="bundle-quantity-selector"
    data-section-id="{{ section_id }}"
    data-base-price="{{ celine_base_price }}"
    data-cart-add-url="{{ routes.cart_add_url }}"
  >
    <script type="application/json" data-bundle-variants>
      {{ product.variants | json }}
    </script>

    <h2 class="bundle-quantity-selector__heading h4">{{ 'celine.product.bundle_heading' | t }}</h2>

    <fieldset class="bundle-quantity-selector__tiers">
      <legend class="visually-hidden">{{ 'celine.product.bundle_heading' | t }}</legend>

      {%- for tier in (1..4) -%}
        {%- liquid
          case tier
            when 1
              assign tier_percent = 0
              assign tier_label = 'celine.product.bundle_tier_1' | t
            when 2
              assign tier_percent = 10
              assign tier_label = 'celine.product.bundle_tier_2' | t
            when 3
              assign tier_percent = 15
              assign tier_label = 'celine.product.bundle_tier_3' | t
            when 4
              assign tier_percent = 20
              assign tier_label = 'celine.product.bundle_tier_4' | t
          endcase

          assign tier_discount_factor = 100 | minus: tier_percent
          assign tier_item_price_cents = celine_base_price | times: tier_discount_factor | divided_by: 100
          assign tier_total_cents = tier_item_price_cents | times: tier
          assign tier_was_total_cents = celine_compare_price | times: tier
          assign tier_item_price_money = tier_item_price_cents | money
          assign tier_total_price_money = tier_total_cents | money
          assign tier_was_price_money = tier_was_total_cents | money
        -%}
        <label
          class="bundle-quantity-selector__tier"
          for="BundleTier-{{ section_id }}-{{ tier }}"
        >
          <input
            type="radio"
            name="bundle-tier-{{ section_id }}"
            id="BundleTier-{{ section_id }}-{{ tier }}"
            value="{{ tier }}"
            data-item-price="{{ tier_item_price_cents }}"
            data-total-price="{{ tier_total_cents }}"
            data-was-price="{{ tier_was_total_cents }}"
            class="bundle-quantity-selector__radio"
            {% if tier == 1 %}checked{% endif %}
          >
          <span class="bundle-quantity-selector__dot" aria-hidden="true"></span>
          <span class="bundle-quantity-selector__tier-body">
            <span class="bundle-quantity-selector__tier-label">{{ tier_label }}</span>
            <span class="bundle-quantity-selector__tier-price">
              <span class="bundle-quantity-selector__price-each">
                {{- 'celine.product.bundle_price_each' | t: price: tier_item_price_money -}}
              </span>
              {%- if tier_percent > 0 -%}
                <span class="bundle-quantity-selector__price-total">
                  {{- 'celine.product.bundle_price_total' | t: price: tier_total_price_money -}}
                  <s class="bundle-quantity-selector__price-was">{{ tier_was_price_money }}</s>
                </span>
              {%- endif -%}
            </span>
          </span>
        </label>
      {%- endfor -%}
    </fieldset>

    {%- for unit in (1..celine_bundle_max_units) -%}
      <div
        class="bundle-quantity-selector__unit"
        data-bundle-unit="{{ unit }}"
        {% if unit > 1 %}hidden{% endif %}
      >
        <p class="bundle-quantity-selector__unit-label">
          {{ 'celine.product.bundle_unit_label' | t: index: unit }}
        </p>
        <div class="bundle-quantity-selector__unit-selects">
          {%- for option in product.options_with_values -%}
            <div class="bundle-quantity-selector__field">
              <label
                class="form__label visually-hidden"
                for="BundleUnit-{{ section_id }}-{{ unit }}-Option-{{ forloop.index0 }}"
              >
                {{ option.name }} — {{ 'celine.product.bundle_unit_label' | t: index: unit }}
              </label>
              <div class="select">
                <select
                  id="BundleUnit-{{ section_id }}-{{ unit }}-Option-{{ forloop.index0 }}"
                  class="select__select"
                  data-bundle-option="{{ forloop.index0 }}"
                >
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}">{{ value }}</option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper select__select-icon" aria-hidden="true">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          {%- else -%}
            <p class="bundle-quantity-selector__no-options">
              {{ 'celine.product.bundle_single_variant' | t }}
            </p>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}

    <div class="bundle-quantity-selector__actions">
      <button
        type="button"
        class="bundle-quantity-selector__add button button--full-width"
        data-bundle-add-button
      >
        <span data-bundle-add-label>{{ 'celine.product.bundle_add_to_cart' | t }}</span>
        {%- render 'loading-spinner' -%}
      </button>
      <p
        class="bundle-quantity-selector__status visually-hidden"
        role="status"
        aria-live="polite"
        data-bundle-status
      ></p>
    </div>
  </bundle-quantity-selector>

  <script src="{{ 'bundle-quantity-selector.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
